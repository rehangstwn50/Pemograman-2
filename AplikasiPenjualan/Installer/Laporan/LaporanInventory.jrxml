                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </pageHeader>

    <detail>
        <band height="16" splitType="Stretch">
            <!-- Zebra biasa -->
            <rectangle>
                <reportElement x="0" y="0" width="782" height="16"
                               backcolor="#F0FAF8" forecolor="#F0FAF8" mode="Opaque"
                               uuid="a1b2c3d4-2222-2222-2222-400000000001">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0 && $F{stok} > $F{stok_minimum}]]></printWhenExpression>
                </reportElement>
            </rectangle>
            <!-- Highlight merah jika stok menipis/habis -->
            <rectangle>
                <reportElement x="0" y="0" width="782" height="16"
                               backcolor="#FFE0E0" forecolor="#FFE0E0" mode="Opaque"
                               uuid="a1b2c3d4-2222-2222-2222-400000000002">
                    <printWhenExpression><![CDATA[$F{stok} <= $F{stok_minimum}]]></printWhenExpression>
                </reportElement>
            </rectangle>
            <textField>
                <reportElement x="0" y="0" width="25" height="16"
                               uuid="a1b2c3d4-2222-2222-2222-400000000003"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
