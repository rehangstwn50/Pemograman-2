<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="LaporanInventory"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="782" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              uuid="a1b2c3d4-2222-2222-2222-000000000002">

    <parameter name="nama_toko" class="java.lang.String">
        <defaultValueExpression><![CDATA["Toko Sejahtera"]]></defaultValueExpression>
    </parameter>
    <parameter name="tgl_awal"  class="java.sql.Date"/>
    <parameter name="tgl_akhir" class="java.sql.Date"/>

    <queryString>
        <![CDATA[
        SELECT
            b.kode_barang,
            b.nama_barang,
            b.kategori,
            b.satuan,
            b.stok,
            b.stok_minimum,
            b.harga_beli,
            b.harga_jual,
            (b.stok * b.harga_beli)       AS nilai_stok,
            CASE
                WHEN b.stok = 0               THEN 'HABIS'
                WHEN b.stok <= b.stok_minimum THEN 'MENIPIS'
                ELSE 'AMAN'
            END                           AS status_stok,
            COALESCE(s.nama_supplier,'-') AS nama_supplier
        FROM barang b
        LEFT JOIN supplier s ON b.kode_supplier = s.kode_supplier
        ORDER BY b.kategori, b.nama_barang
        ]]>
    </queryString>

    <field name="kode_barang"   class="java.lang.String"/>
    <field name="nama_barang"   class="java.lang.String"/>
    <field name="kategori"      class="java.lang.String"/>
    <field name="satuan"        class="java.lang.String"/>
    <field name="stok"          class="java.lang.Integer"/>
    <field name="stok_minimum"  class="java.lang.Integer"/>
    <field name="harga_beli"    class="java.lang.Double"/>
    <field name="harga_jual"    class="java.lang.Double"/>
    <field name="nilai_stok"    class="java.lang.Double"/>
    <field name="status_stok"   class="java.lang.String"/>
    <field name="nama_supplier" class="java.lang.String"/>

    <variable name="totalNilaiStok" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{nilai_stok}]]></variableExpression>
    </variable>
    <variable name="totalItem" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{kode_barang}]]></variableExpression>
    </variable>

    <group name="grpKategori">
        <groupExpression><![CDATA[$F{kategori}]]></groupExpression>
        <groupHeader>
            <band height="20" splitType="Stretch">
                <rectangle>
                    <reportElement x="0" y="2" width="782" height="16"
                                   backcolor="#C8E6E1" forecolor="#C8E6E1" mode="Opaque"
                                   uuid="a1b2c3d4-2222-2222-2222-100000000001"/>
                </rectangle>
                <textField>
                    <reportElement x="4" y="2" width="400" height="16"
                                   forecolor="#1E7A6E"
                                   uuid="a1b2c3d4-2222-2222-2222-100000000002"/>
                    <textElement verticalAlignment="Middle">
                        <font isBold="true" size="9"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Kategori: " + $F{kategori}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="6" splitType="Stretch">
                <line>
                    <reportElement x="0" y="0" width="782" height="1"
                                   forecolor="#AAAAAA"
                                   uuid="a1b2c3d4-2222-2222-2222-100000000003"/>
                </line>
            </band>
        </groupFooter>
    </group>

    <title>
        <band height="60" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="0" width="782" height="28"
                               forecolor="#1E7A6E"
                               uuid="a1b2c3d4-2222-2222-2222-200000000001"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="18" isBold="true" fontName="Arial"/>
                </textElement>
                <text><![CDATA[LAPORAN INVENTORY STOK BARANG]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="28" width="782" height="16"
                               uuid="a1b2c3d4-2222-2222-2222-200000000002"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{nama_toko}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="44" width="782" height="14"
                               uuid="a1b2c3d4-2222-2222-2222-200000000003"/>
                <textElement textAlignment="Center">
                    <font size="9" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Per Tanggal: " + new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id","ID")).format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </title>

