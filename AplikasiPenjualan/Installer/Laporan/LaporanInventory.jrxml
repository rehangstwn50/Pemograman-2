                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Nilai Stok]]></text>
            </staticText>
            <staticText>
                <reportElement x="725" y="0" width="57" height="22" forecolor="WHITE"
